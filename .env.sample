# BYO Thread Storage — 環境變數範本
# 複製此檔案為 .env 並填入您的實際值：cp .env.sample .env

# ============================================================
# 必填：Azure Cosmos DB 帳號端點
# 在 Azure Portal → Cosmos DB 帳號 → 金鑰 → URI 中取得
# ============================================================
COSMOS_ENDPOINT=https://your-cosmosdb-account.documents.azure.com:443/

# ============================================================
# 選填：Cosmos DB 資料庫與容器名稱（有預設值）
# ============================================================
COSMOS_DATABASE_NAME=thread_storage
COSMOS_CONTAINER_NAME=threads

# ============================================================
# 選填：Azure AI Foundry 專案端點
# 使用 agent_integration.py 時需要
# 在 Azure AI Foundry 專案設定 → 端點 中取得
# ============================================================
AZURE_AI_PROJECT_ENDPOINT=https://your-foundry-project.api.azureml.ms
